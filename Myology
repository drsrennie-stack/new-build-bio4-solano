function escapeHTML(s) {
  return s.replace(/[&<>"']/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c]));
}

function wireDetailHandlers() {
  const scopeToggle = document.getElementById('rp-scope-toggle');
  if (scopeToggle) {
    const toggle = () => {
      const [catId, idx] = parseKey(state.panel.detailKey);
      state.examScope[catId][idx] = !state.examScope[catId][idx];
      // If excluded, un-exclude — they're mutually exclusive semantically
      if (state.examScope[catId][idx] && state.excluded[catId][idx]) {
        state.excluded[catId][idx] = false;
      }
      renderPanel();
      renderTable();
      updateDueBadge();
      saveState();
    };
    scopeToggle.addEventListener('click', toggle);
    scopeToggle.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  }
  const notesEl = document.getElementById('rp-notes');
  if (notesEl) {
    let t;
    notesEl.addEventListener('input', function() {
      const v = this.value;
      clearTimeout(t);
      t = setTimeout(() => {
        if (v) state.notes[state.panel.detailKey] = v;
        else delete state.notes[state.panel.detailKey];
        saveState();
      }, 200);
    });
  }
  document.querySelectorAll('.rp-xref-item[data-jump]').forEach(item => {
    item.addEventListener('click', () => {
      const k = item.dataset.jump;
      const [catId] = parseKey(k);
      if (catId !== state.cur) {
        state.cur = catId;
        document.querySelectorAll('.sb-btn').forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
          if (b.dataset.id === catId) {
            b.classList.add('active');
            b.setAttribute('aria-pressed', 'true');
          }
        });
        updateHeader();
      }
      state.panel.detailKey = k;
      renderPanel();
      renderTable();
      saveState();
    });
  });
}

/* ── Review session ── */
function startReviewSession() {
  const queue = buildReviewQueue();
  if (queue.length === 0) return;
  reviewSession = {
    queue,
    idx: 0,
    shown: false,
    stats: { reviewed: 0, again: 0, hard: 0, good: 0, easy: 0 },
  };
  openPanel('review');
}

function renderReviewHTML() {
  if (!reviewSession) return renderIdleHTML();
  const { queue, idx, shown, stats } = reviewSession;

  // Session done
  if (idx >= queue.length) {
    return `<div class="rp-done">
      <div class="rp-done-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="rp-done-title">Session complete</div>
      <div class="rp-done-sub">Great work. Come back when more cards are due.</div>
      <div class="rp-done-stats">
        <div class="rp-done-stat"><div class="rp-done-stat-num">${stats.reviewed}</div><div class="rp-done-stat-label">Reviewed</div></div>
        <div class="rp-done-stat"><div class="rp-done-stat-num" style="color:var(--c-i)">${stats.good + stats.easy}</div><div class="rp-done-stat-label">Strong</div></div>
        <div class="rp-done-stat"><div class="rp-done-stat-num" style="color:#B53A1A">${stats.again}</div><div class="rp-done-stat-label">Restarts</div></div>
      </div>
      <button class="rp-start-btn" id="rp-back-idle">Back to overview</button>
    </div>`;
  }

  const k = queue[idx];
  const [catId, mIdx] = parseKey(k);
  const info = getMuscle(catId, mIdx);
  if (!info) {
    // Skip and advance
    reviewSession.idx++;
    return renderReviewHTML();
  }
  const { muscle, cat } = info;
  const card = state.cards[k];

  const progress = `
    <div class="rp-review-progress">
      Card <strong>${idx + 1}</strong> of <strong>${queue.length}</strong>
      &nbsp;·&nbsp; <strong>${stats.reviewed}</strong> reviewed this session
    </div>
  `;

  if (!shown) {
    return progress + `
      <div class="rp-card">
        <div class="rp-card-cat">${cat.lb}</div>
        <div class="rp-card-name">${muscle.n}</div>
        <div class="rp-card-prompt">Recall Origin, Insertion, Action, and Innervation</div>
        <button class="rp-show-answer" id="rp-show">Show answer</button>
      </div>
    `;
  }

  // Answer shown
  return progress + `
    <div class="rp-answer">
      <div class="rp-answer-cat">${cat.lb}</div>
      <div class="rp-answer-name">${muscle.n}</div>
      <div class="rp-field f-o">
        <div class="rp-field-label">Origin</div>
        <div class="rp-field-text">${muscle.o}</div>
      </div>
      <div class="rp-field f-i">
        <div class="rp-field-label">Insertion</div>
        <div class="rp-field-text">${muscle.i}</div>
      </div>
      <div class="rp-field f-a">
        <div class="rp-field-label">Action</div>
        <div class="rp-field-text">${muscle.a}</div>
      </div>
      <div class="rp-field f-n">
        <div class="rp-field-label">Innervation</div>
        <div class="rp-field-text">${muscle.v}</div>
      </div>
    </div>
    <div class="rp-ratings">
      <button class="rp-rate-btn" data-r="again">
        <span class="rp-rate-label">Again</span>
        <span class="rp-rate-interval">${formatInterval(previewInterval(card, 'again'))}</span>
      </button>
      <button class="rp-rate-btn" data-r="hard">
        <span class="rp-rate-label">Hard</span>
        <span class="rp-rate-interval">${formatInterval(previewInterval(card, 'hard'))}</span>
      </button>
      <button class="rp-rate-btn" data-r="good">
        <span class="rp-rate-label">Good</span>
        <span class="rp-rate-interval">${formatInterval(previewInterval(card, 'good'))}</span>
      </button>
      <button class="rp-rate-btn" data-r="easy">
        <span class="rp-rate-label">Easy</span>
        <span class="rp-rate-interval">${formatInterval(previewInterval(card, 'easy'))}</span>
      </button>
    </div>
  `;
}

function wireReviewHandlers() {
  const show = document.getElementById('rp-show');
  if (show) {
    show.addEventListener('click', () => {
      reviewSession.shown = true;
      renderPanel();
    });
  }
  document.querySelectorAll('.rp-rate-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const r = btn.dataset.r;
      const k = reviewSession.queue[reviewSession.idx];
      const prev = state.cards[k];
      state.cards[k] = schedule(prev, r);
      reviewSession.stats.reviewed++;
      reviewSession.stats[r]++;
      reviewSession.idx++;
      reviewSession.shown = false;
      renderPanel();
      updateDueBadge();
      refreshSidebarStats();
      saveState();
    });
  });
  const back = document.getElementById('rp-back-idle');
  if (back) {
    back.addEventListener('click', () => {
      reviewSession = null;
      state.panel.mode = 'idle';
      renderPanel();
      saveState();
    });
  }
  // Keyboard shortcuts: space to show, 1-4 to rate
  document.addEventListener('keydown', reviewKeyHandler);
}
function reviewKeyHandler(e) {
  if (state.panel.mode !== 'review' || !reviewSession) return;
  if (document.activeElement && (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA')) return;
  if (reviewSession.idx >= reviewSession.queue.length) return;
  if (!reviewSession.shown) {
    if (e.key === ' ' || e.key === 'Enter') {
      e.preventDefault();
      reviewSession.shown = true;
      renderPanel();
    }
  } else {
    const map = { '1': 'again', '2': 'hard', '3': 'good', '4': 'easy' };
    if (map[e.key]) {
      e.preventDefault();
      const btn = document.querySelector(`.rp-rate-btn[data-r="${map[e.key]}"]`);
      if (btn) btn.click();
    }
  }
}

function updateDueBadge() {
  const queue = buildReviewQueue();
  const badge = document.getElementById('due-badge');
  const text = document.getElementById('due-badge-text');
  const n = queue.length;
  text.textContent = `${n} due`;
  badge.classList.toggle('zero', n === 0);
  badge.setAttribute('aria-label', `${n} card${n === 1 ? '' : 's'} due for review`);
}

