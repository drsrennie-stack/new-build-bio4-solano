function announce(msg) {
  const el = document.getElementById('sr-status');
  el.textContent = '';
  setTimeout(() => { el.textContent = msg; }, 50);
}

/* ════════════════════════════════════════════════════
   CATEGORY STATS
   ════════════════════════════════════════════════════ */
function catStats(catId) {
  const cat = DATA.find(c => c.id === catId);
  const cols = state.showInn ? ['o','i','a','v'] : ['o','i','a'];
  let active = 0, total = 0, revealed = 0, excluded = 0, muscles = 0;
  let x = 0;
  cat.s.forEach(s => s.m.forEach(() => {
    muscles++;
    const isEx = state.excluded[catId][x];
    if (isEx) { excluded++; }
    else {
      active++;
      cols.forEach(c => {
        total++;
        if (state.reveals[catId][x][c]) revealed++;
      });
    }
    x++;
  }));
  return { active, total, revealed, excluded, muscles, pct: total ? Math.round(revealed/total*100) : 0 };
}

function allStats() {
  let totRev = 0, totTot = 0, totSkip = 0;
  DATA.forEach(c => {
    const s = catStats(c.id);
    totRev += s.revealed;
    totTot += s.total;
    totSkip += s.excluded;
  });
  return { rev: totRev, tot: totTot, skip: totSkip, pct: totTot ? Math.round(totRev/totTot*100) : 0 };
}

