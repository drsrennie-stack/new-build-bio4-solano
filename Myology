let reviewSession = null; // { queue, idx, shown, stats: {reviewed, again, hard, good, easy} }

function openPanel(mode, opts) {
  state.panel.open = true;
  state.panel.mode = mode || 'idle';
  if (opts && opts.detailKey) state.panel.detailKey = opts.detailKey;
  document.getElementById('right-panel').classList.add('open');
