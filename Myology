}

function closePanel() {
  state.panel.open = false;
  if (state.panel.mode === 'review') state.panel.mode = 'idle';
  reviewSession = null;
  document.getElementById('right-panel').classList.remove('open');
  // Refresh table to clear any active-detail highlight
  renderTable();
  saveState();
}

function renderPanel() {
  const titleEl = document.getElementById('rp-title');
  const contentEl = document.getElementById('rp-content');
  if (state.panel.mode === 'idle') {
    titleEl.textContent = 'Review';
    contentEl.innerHTML = renderIdleHTML();
