function renderTable() {
  const cat = DATA.find(c => c.id === state.cur);
  const wrap = document.getElementById('table-wrap');
  wrap.innerHTML = '';
  const hc = state.showInn ? '' : ' hide-col';
  const searchQ = state.search.trim().toLowerCase();

  let gi = 0;
  let anyVisible = false;

  cat.s.forEach(sec => {
    // Count visible muscles in this section
    const startGi = gi;
    const visibleInSection = sec.m.filter((m, idx) => {
      const globalIdx = startGi + idx;
      const isExcl = state.excluded[state.cur][globalIdx];
      if (state.hideExcl && isExcl) return false;
      if (searchQ && !m.n.toLowerCase().includes(searchQ)) return false;
      return true;
    });

    if (visibleInSection.length === 0) {
      gi += sec.m.length;
      return;
    }
    anyVisible = true;

    const sectionHeader = document.createElement('div');
    sectionHeader.className = 'section-header';
    sectionHeader.setAttribute('role','heading');
    sectionHeader.setAttribute('aria-level','2');
    sectionHeader.innerHTML = `
      <span class="section-title">${sec.t}</span>
      <span class="section-count">${visibleInSection.length} of ${sec.m.length}</span>
    `;
    wrap.appendChild(sectionHeader);

    const tblWrap = document.createElement('div');
    tblWrap.style.overflowX = 'auto';
    const tbl = document.createElement('table');
    tbl.setAttribute('role','table');
    tbl.setAttribute('aria-label', sec.t);
    tbl.innerHTML = `<thead role="rowgroup"><tr role="row">
      <th scope="col" style="text-align:center;">On list?</th>
      <th scope="col" class="muscle-col">Muscle</th>
      <th scope="col" class="col-o">Origin</th>
      <th scope="col" class="col-i">Insertion</th>
      <th scope="col" class="col-a">Action</th>
      <th scope="col" class="col-n${hc}">Innervation</th>
    </tr></thead>`;
    const tbody = document.createElement('tbody');
    tbody.setAttribute('role','rowgroup');
    tbl.appendChild(tbody);
    tblWrap.appendChild(tbl);
    wrap.appendChild(tblWrap);

    sec.m.forEach(m => {
      const idx = gi++;
      const r = state.reveals[state.cur][idx];
      const isExcl = state.excluded[state.cur][idx];

      if (state.hideExcl && isExcl) return;
      if (searchQ && !m.n.toLowerCase().includes(searchQ)) return;

      const tr = document.createElement('tr');
      tr.setAttribute('role','row');
      if (isExcl) tr.classList.add('excluded');

      // Skip + Scope toggles
      const skipTd = document.createElement('td');
      skipTd.className = 'skip-col';
      const togglesWrap = document.createElement('div');
      togglesWrap.className = 'row-toggles';

      const isInScope = !!state.examScope[state.cur]?.[idx];
      const thisKey = cardKey(state.cur, idx);
      const isActiveDetail = state.panel.open && state.panel.mode === 'detail' && state.panel.detailKey === thisKey;

      // Skip button
      const skipBtn = document.createElement('button');
      skipBtn.className = 'row-toggle-btn skip-btn' + (isExcl ? ' checked' : '');
      skipBtn.setAttribute('aria-pressed', isExcl ? 'true' : 'false');
      skipBtn.setAttribute('aria-label', isExcl ? `${m.n}: marked as skipped. Click to include.` : `${m.n}: skip (not on my list)`);
      skipBtn.setAttribute('title', isExcl ? 'Click to include this muscle' : 'Skip — not on my list');
      skipBtn.innerHTML = '<span class="pill-dot" aria-hidden="true"></span><span>Skip</span>';
      skipBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const newVal = !state.excluded[state.cur][idx];
        state.excluded[state.cur][idx] = newVal;
        // Mutually exclusive: skipping removes from exam scope
        if (newVal && state.examScope[state.cur][idx]) {
          state.examScope[state.cur][idx] = false;
        }
        announce(newVal ? `${m.n} marked as skipped` : `${m.n} included again`);
        renderTable();
        refreshSidebarStats();
        updateScore();
        updateDueBadge();
        if (state.panel.open && state.panel.mode === 'idle') renderPanel();
        saveState();
      });
      togglesWrap.appendChild(skipBtn);

      // Scope button (bookmark)
      const scopeBtn = document.createElement('button');
      scopeBtn.className = 'row-toggle-btn scope-btn' + (isInScope ? ' checked' : '');
      scopeBtn.setAttribute('aria-pressed', isInScope ? 'true' : 'false');
      scopeBtn.setAttribute('aria-label', isInScope ? `${m.n}: in exam scope. Click to remove.` : `${m.n}: add to exam scope`);
      scopeBtn.setAttribute('title', isInScope ? 'In exam scope — click to remove' : 'Add to exam scope');
      scopeBtn.innerHTML = '<span class="pill-dot" aria-hidden="true"></span><span>On Exam</span>';
      scopeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const newVal = !state.examScope[state.cur][idx];
        state.examScope[state.cur][idx] = newVal;
        if (newVal && state.excluded[state.cur][idx]) {
          state.excluded[state.cur][idx] = false;
        }
        announce(newVal ? `${m.n} added to exam scope` : `${m.n} removed from exam scope`);
        renderTable();
        refreshSidebarStats();
        updateScore();
        updateDueBadge();
        if (state.panel.open && (state.panel.mode === 'idle' || (state.panel.mode === 'detail' && state.panel.detailKey === thisKey))) {
          renderPanel();
        }
        saveState();
      });
      togglesWrap.appendChild(scopeBtn);

      skipTd.appendChild(togglesWrap);
      tr.appendChild(skipTd);

      // Muscle name (clickable to open detail panel)
      const nameTd = document.createElement('td');
      nameTd.setAttribute('role','rowheader');
      const nameDiv = document.createElement('div');
      nameDiv.className = 'muscle-name' + (isActiveDetail ? ' active-detail' : '');
      nameDiv.setAttribute('role', 'button');
      nameDiv.setAttribute('tabindex', '0');
      nameDiv.setAttribute('aria-label', `${m.n} — open detail panel`);
      nameDiv.innerHTML = `<span class="row-dot" style="background:${cat._col}" aria-hidden="true"></span><span class="muscle-name-text">${m.n}</span>`;
      const openDetail = () => {
        state.panel.detailKey = thisKey;
        openPanel('detail');
        renderTable(); // refresh to highlight
      };
      nameDiv.addEventListener('click', openDetail);
      nameDiv.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openDetail(); }
      });
      nameTd.appendChild(nameDiv);
      tr.appendChild(nameTd);

      // Cells
      [['o','col-o',m.o],['i','col-i',m.i],['a','col-a',m.a],['v','col-n'+hc,m.v]].forEach(([key, cls, val]) => {
        const td = document.createElement('td');
        td.className = cls;
        td.setAttribute('role','cell');
        const isRev = r[key];
        const btn = document.createElement('button');
        btn.className = 'cell-btn' + (isRev ? ' revealed' : '');
        btn.textContent = val;
        btn.setAttribute('aria-label', isRev ? `${m.n} ${COL_LABELS[key]}: ${val}` : `${m.n} ${COL_LABELS[key]}: hidden, press to reveal`);
        btn.setAttribute('aria-expanded', isRev ? 'true' : 'false');
        if (isRev) btn.setAttribute('aria-disabled', 'true');
        btn.dataset.col = key;
