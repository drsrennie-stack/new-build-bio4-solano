/* ════════════════════════════════════════════════════
   SPACED REPETITION — scheduling + queue
   ════════════════════════════════════════════════════ */
const DAY_MS = 24 * 60 * 60 * 1000;

function cardKey(catId, idx) { return catId + ':' + idx; }
function parseKey(k) { const i = k.indexOf(':'); return [k.slice(0, i), Number(k.slice(i + 1))]; }

function getMuscle(catId, idx) {
  const cat = DATA.find(c => c.id === catId);
  if (!cat) return null;
  let gi = 0;
  for (const sec of cat.s) {
    for (const m of sec.m) {
      if (gi === idx) return { muscle: m, cat, section: sec, idx };
      gi++;
    }
  }
  return null;
}

// SM-2-inspired interval calculation. Returns { interval (days), dueDate, lastReviewed, reviews }
function schedule(card, rating) {
  const now = Date.now();
  const prevReviews = (card && card.reviews) || 0;
  const prevInterval = (card && card.interval) || 1;
  let interval, reviews = prevReviews + 1;

  if (rating === 'again') {
    interval = 10 / 60 / 24; // 10 min in days
    reviews = 0;
  } else if (rating === 'hard') {
    interval = Math.max(1, prevInterval * 1.2);
  } else if (rating === 'good') {
    if (prevReviews === 0) interval = 1;
    else if (prevReviews === 1) interval = 3;
    else interval = prevInterval * 2.5;
  } else { // easy
    if (prevReviews === 0) interval = 3;
    else interval = prevInterval * 4;
  }

  return {
    interval,
    dueDate: now + interval * DAY_MS,
    lastReviewed: now,
    reviews,
  };
}

// Preview the interval for a given rating without committing
function previewInterval(card, rating) {
  const prevReviews = (card && card.reviews) || 0;
  const prevInterval = (card && card.interval) || 1;
  if (rating === 'again') return 10 / 60 / 24;
  if (rating === 'hard') return Math.max(1, prevInterval * 1.2);
  if (rating === 'good') {
    if (prevReviews === 0) return 1;
    if (prevReviews === 1) return 3;
    return prevInterval * 2.5;
  }
  if (rating === 'easy') {
    if (prevReviews === 0) return 3;
    return prevInterval * 4;
  }
  return 1;
}

function formatInterval(days) {
  if (days < 1 / 24) return Math.round(days * 24 * 60) + 'm';
  if (days < 1) return Math.round(days * 24) + 'h';
  if (days < 30) return Math.round(days) + 'd';
  if (days < 365) return Math.round(days / 30) + 'mo';
  return Math.round(days / 365) + 'y';
}

function formatRelative(dueDate) {
  const diff = dueDate - Date.now();
  if (diff <= 0) return 'Due now';
  return 'in ' + formatInterval(diff / DAY_MS);
}

function daysUntilExam() {
  if (!state.examDate) return null;
  const exam = new Date(state.examDate + 'T23:59:59');
  if (isNaN(exam.getTime())) return null;
  return Math.ceil((exam.getTime() - Date.now()) / DAY_MS);
}

// Build the review queue: cards in scope that are due, sorted by overdueness
function buildReviewQueue() {
  const now = Date.now();
  const queue = [];
  DATA.forEach(cat => {
    let gi = 0;
    cat.s.forEach(sec => sec.m.forEach(() => {
      const inScope = state.examScope[cat.id]?.[gi];
      const skipped = state.excluded[cat.id][gi];
      if (inScope && !skipped) {
        const k = cardKey(cat.id, gi);
        const card = state.cards[k];
        if (!card || card.dueDate <= now) {
          const dueness = card ? now - card.dueDate : Infinity;
          queue.push({ key: k, dueness });
        }
      }
      gi++;
    }));
  });
  queue.sort((a, b) => b.dueness - a.dueness);
  return queue.map(q => q.key);
}

function getScopeSummary() {
  const now = Date.now();
  let inScope = 0, dueNow = 0, due24 = 0, dueWeek = 0, learned = 0, mature = 0;
  DATA.forEach(cat => {
    let gi = 0;
    cat.s.forEach(sec => sec.m.forEach(() => {
      const isInScope = state.examScope[cat.id]?.[gi];
      const skipped = state.excluded[cat.id][gi];
      if (isInScope && !skipped) {
        inScope++;
        const card = state.cards[cardKey(cat.id, gi)];
        if (!card || card.dueDate <= now) dueNow++;
        else if (card.dueDate <= now + DAY_MS) due24++;
        else if (card.dueDate <= now + 7 * DAY_MS) dueWeek++;
        if (card && card.reviews >= 2) learned++;
        if (card && card.interval >= 21) mature++;
      }
      gi++;
    }));
  });
  return { inScope, dueNow, due24, dueWeek, learned, mature };
}

function computeXrefs(forMuscle, forCatId, forIdx) {
  // Same nerve (exact match on v field)
  const sameNerve = [];
  DATA.forEach(cat => {
    let gi = 0;
    cat.s.forEach(sec => sec.m.forEach(m => {
      if (!(cat.id === forCatId && gi === forIdx)) {
        if (m.v === forMuscle.v) sameNerve.push({ m, cat, idx: gi });
      }
      gi++;
    }));
  });
  return { sameNerve };
}

