    searchEl.focus();
  }
  if (e.key === 'Escape' && document.activeElement === searchEl) {
    searchEl.value = '';
    state.search = '';
    searchClear.classList.remove('visible');
    renderTable();
    searchEl.blur();
  }
});

/* ════════════════════════════════════════════════════
   PANEL EVENT HANDLERS
   ════════════════════════════════════════════════════ */
document.getElementById('rp-close').addEventListener('click', closePanel);

document.getElementById('panel-toggle').addEventListener('click', () => {
  if (state.panel.open) closePanel();
  else {
    const mode = state.panel.mode === 'detail' && state.panel.detailKey ? 'detail' : 'idle';
    openPanel(mode);
  }
});

document.getElementById('due-badge').addEventListener('click', () => {
  const queue = buildReviewQueue();
  if (queue.length > 0) {
    startReviewSession();
  } else {
    openPanel('idle');
  }
});

// Esc closes panel (unless typing in a field)
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && state.panel.open) {
    const tag = document.activeElement?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;
    closePanel();
  }
});

/* ════════════════════════════════════════════════════
   INIT
   ════════════════════════════════════════════════════ */
buildSidebar();
updateHeader();
renderTable();
refreshSidebarStats();
updateDueBadge();
// Restore panel state if it was open (only idle/detail; review sessions don't persist)
if (state.panel.open && (state.panel.mode === 'idle' || state.panel.mode === 'detail')) {
  document.getElementById('right-panel').classList.add('open');
  renderPanel();
}
</script>
</body>
</html>
