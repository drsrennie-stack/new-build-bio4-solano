          ? `<div class="rp-exam-countdown">Exam date has passed</div>`
          : `<div class="rp-exam-countdown">Set a date to plan your reviews</div>`}
    </div>
  `;

  let scopeHTML;
  if (sum.inScope === 0) {
    scopeHTML = `
      <div class="rp-empty-scope">
        <strong>No cards in your exam scope yet.</strong><br>
        Click the bookmark icon next to a muscle in the table to add it. Only cards you select will appear in review sessions.
      </div>
    `;
  } else {
    scopeHTML = `
      <div class="rp-idle-grid">
        <div class="rp-stat-card">
          <div class="rp-stat-label">Due now</div>
          <div class="rp-stat-num due">${sum.dueNow}</div>
        </div>
        <div class="rp-stat-card">
          <div class="rp-stat-label">In scope</div>
          <div class="rp-stat-num">${sum.inScope}</div>
        </div>
      </div>
      <button class="rp-start-btn" id="rp-start-review" ${queue.length === 0 ? 'disabled' : ''}>
        ${queue.length === 0 ? 'No cards due — check back later' : `Start review · ${queue.length} card${queue.length === 1 ? '' : 's'}`}
      </button>
      <div class="rp-section-h">Upcoming</div>
      <ul class="rp-upcoming">
        <li>In the next 24 hours <strong>${sum.due24}</strong></li>
        <li>Later this week <strong>${sum.dueWeek}</strong></li>
        <li>Learned (2+ reviews) <strong>${sum.learned}</strong></li>
        <li>Mature (21+ days) <strong>${sum.mature}</strong></li>
