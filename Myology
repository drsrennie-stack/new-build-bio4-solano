/* ════════════════════════════════════════════════════
   STATE — with localStorage persistence
   ════════════════════════════════════════════════════ */
const STORAGE_KEY = 'myology-atlas-v1';

function defaultState() {
  const reveals = {};
  const excluded = {};
  const examScope = {};
  DATA.forEach(c => {
    reveals[c.id] = {};
    excluded[c.id] = {};
    examScope[c.id] = {};
    let x = 0;
    c.s.forEach(s => s.m.forEach(() => {
      reveals[c.id][x] = { o:false, i:false, a:false, v:false };
      excluded[c.id][x] = false;
      examScope[c.id][x] = false;
      x++;
    }));
  });
  return {
    cur: DATA[0].id,
    quizMode: true,
    showInn: true,
    hideExcl: false,
    search: '',
    reveals,
    excluded,
    examScope,
    cards: {},        // key: "catId:idx" → { interval, dueDate, lastReviewed, reviews }
    notes: {},        // key: "catId:idx" → string
    examDate: '',     // ISO date string (yyyy-mm-dd) or empty
    panel: { open: false, mode: 'idle', detailKey: null },
  };
}

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return defaultState();
    const saved = JSON.parse(raw);
    const def = defaultState();
    def.cur = saved.cur && DATA.find(c => c.id === saved.cur) ? saved.cur : def.cur;
    def.quizMode = typeof saved.quizMode === 'boolean' ? saved.quizMode : true;
    def.showInn = typeof saved.showInn === 'boolean' ? saved.showInn : true;
    def.hideExcl = typeof saved.hideExcl === 'boolean' ? saved.hideExcl : false;
    // Sanitize stored exam date — drop if year is obviously wrong (covers stale typo-years)
    if (typeof saved.examDate === 'string' && saved.examDate) {
      const year = Number(saved.examDate.slice(0, 4));
      const currentYear = new Date().getFullYear();
      def.examDate = (year >= currentYear && year <= currentYear + 5) ? saved.examDate : '';
    } else {
      def.examDate = '';
    }
    DATA.forEach(c => {
      let x = 0;
      c.s.forEach(s => s.m.forEach(() => {
        if (saved.reveals?.[c.id]?.[x]) {
          def.reveals[c.id][x] = {
            o: !!saved.reveals[c.id][x].o,
            i: !!saved.reveals[c.id][x].i,
            a: !!saved.reveals[c.id][x].a,
            v: !!saved.reveals[c.id][x].v,
          };
        }
        if (saved.excluded?.[c.id]?.[x] !== undefined) {
          def.excluded[c.id][x] = !!saved.excluded[c.id][x];
        }
        if (saved.examScope?.[c.id]?.[x] !== undefined) {
          def.examScope[c.id][x] = !!saved.examScope[c.id][x];
        }
        x++;
      }));
    });
    if (saved.cards && typeof saved.cards === 'object') {
      Object.keys(saved.cards).forEach(k => {
        const card = saved.cards[k];
        if (card && typeof card === 'object') {
          def.cards[k] = {
            interval: Number(card.interval) || 1,
            dueDate: Number(card.dueDate) || Date.now(),
            lastReviewed: Number(card.lastReviewed) || 0,
            reviews: Number(card.reviews) || 0,
          };
        }
      });
    }
    if (saved.notes && typeof saved.notes === 'object') {
      Object.keys(saved.notes).forEach(k => {
        if (typeof saved.notes[k] === 'string') def.notes[k] = saved.notes[k];
      });
    }
    // Panel state — don't restore review mode mid-session; only restore detail or idle
    def.panel = { open: false, mode: 'idle', detailKey: null };
    return def;
  } catch (e) {
    return defaultState();
  }
}

let state = loadState();

const saveState = (() => {
  let t;
  return () => {
    clearTimeout(t);
    t = setTimeout(() => {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
    }, 120);
  };
})();

